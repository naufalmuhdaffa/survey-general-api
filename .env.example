APP_ENV=development

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=survey_db
DB_USER=root
DB_PASS=

IDENTITY_API_URL=http://example.test # Refers to https://github.com/naufalmuhdaffa/employees-dummy-api
# Run this command in the terminal to generate a random API key: 
# php -r "echo bin2hex(random_bytes(32));"
IDENTITY_API_KEY=

# Run this command in the terminal to generate a random JWT secret key: 
# php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=
JWT_EXPIRE=3600 # JWT expiration time in seconds (e.g., 3600 for 1 hour)

# HTTP-only cookie
COOKIE_NAME=access_token
COOKIE_PATH=/
COOKIE_SECURE=false # true in production/HTTPS
COOKIE_SAMESITE=Lax # Lax, Strict, or None

# Optional. Leave empty for host-only cookie.
# Example production subdomain sharing: .example.com
COOKIE_DOMAIN=

# Required when frontend and API are different origins and cookies use credentials
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
