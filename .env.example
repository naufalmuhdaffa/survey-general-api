APP_ENV=development
APP_FRONTEND_URL=http://localhost:5173

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=survey_db
DB_USER=root
DB_PASS=

IDENTITY_API_URL=http://example.test
# Run this command in the terminal to generate a random API key: 
# php -r "echo bin2hex(random_bytes(32));"
IDENTITY_API_KEY=

# Run this command in the terminal to generate a random JWT secret key: 
# php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=
JWT_EXPIRE=3600 # JWT expiration time in seconds (e.g., 3600 for 1 hour)

# HTTP-only cookie
COOKIE_NAME=access_token
CSRF_COOKIE_NAME=csrf_token
COOKIE_PATH=/
COOKIE_SECURE=false # true in production/HTTPS
COOKIE_SAMESITE=Lax # Lax, Strict, or None

# Optional. Leave empty for host-only cookie.
# Example production subdomain sharing: .example.com
COOKIE_DOMAIN=

# Required when frontend and API are different origins and cookies use credentials
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Contact verification
# Supported: log, mail, smtp. Use log for local development without a mail server.
MAIL_TRANSPORT=log
MAIL_FROM_EMAIL=noreply@survey-jogja.test
MAIL_FROM_NAME="Survey PemKot Jogja"
MAIL_SMTP_HOST=
MAIL_SMTP_PORT=587
MAIL_SMTP_ENCRYPTION=tls # tls, ssl, or none
MAIL_SMTP_USERNAME=
MAIL_SMTP_PASSWORD=

# Optional generic SMS gateway. If empty in development, OTP is written to /storage/logs/sms.log.
SMS_PROVIDER_URL=
SMS_PROVIDER_TOKEN=
SMS_DEV_REDIRECT_PHONE=
